  "version": "1.5.1",
  "name": "GitHub Pages Docs Migration",

  "files": {

    "docs/index.html": {
      "mode": "system",
      "content": "<!DOCTYPE html>\n<html>\n<head>\n<title>BudE StoryBoard AI</title>\n<link rel=\"stylesheet\" href=\"styles.css\">\n</head>\n<body>\n<h1>BudE StoryBoard AI</h1>\n<h2>Creative Command Center</h2>\n\n<div class=\"card\">\n<a href=\"generator.html\">Open Creative Generator</a>\n</div>\n\n<div class=\"card\">\nWorld Builder<br>\nCharacter Studio<br>\nStoryboard Director\n</div>\n\n</body>\n</html>"
    },


    "docs/generator.html": {
      "mode": "system",
      "content": "<!DOCTYPE html>\n<html>\n<head>\n<title>BudE Generator</title>\n<link rel=\"stylesheet\" href=\"styles.css\">\n</head>\n<body>\n<h1>BudE Creative Generator</h1>\n\n<textarea id=\"prompt\" placeholder=\"Describe your idea...\"></textarea>\n\n<select id=\"type\">\n<option value=\"story\">Story</option>\n<option value=\"character\">Character</option>\n<option value=\"world\">World</option>\n</select>\n\n<button onclick=\"generate()\">Generate</button>\n\n<pre id=\"output\">Waiting...</pre>\n\n<script src=\"generator.js\"></script>\n</body>\n</html>"
    },


    "docs/generator.js": {
      "mode": "system",
      "content": "function generate(){\nlet prompt=document.getElementById('prompt').value;\nlet type=document.getElementById('type').value;\n\nlet output={\n type:type,\n prompt:prompt,\n status:'BudE generation request received'\n};\n\ndocument.getElementById('output').textContent=JSON.stringify(output,null,2);\n}"
    },


    "docs/styles.css": {
      "mode": "system",
      "content": "body{background:#0b1220;color:white;font-family:Arial;padding:25px}.card{background:#18253a;padding:20px;margin:15px;border-radius:12px}textarea{width:90%;height:120px}"
    }

  }
}
